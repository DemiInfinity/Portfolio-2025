# Cypress Environment Variables
# Copy this file to .cypress.env and fill in your values
# 
# NOTE: Admin login tests use TEST-ONLY credentials and mock API responses.
# Real admin credentials are NOT used in tests - all API calls are intercepted.

# Admin panel URL (optional, defaults to http://localhost:3002)
ADMIN_URL=http://localhost:3002

# Frontend URL for E2E tests
baseUrl=http://localhost:3000

# API URL (optional, used for some test scenarios)
API_URL=http://localhost:5000

# Test-only credentials (used by step definitions)
# These credentials are ONLY used in tests and API calls are mocked
# Real admin credentials should NEVER be used in Cypress tests
TEST_ADMIN_EMAIL=test-admin@example.com
TEST_ADMIN_PASSWORD=test-password-123

# Environment Configuration
NODE_ENV=development
PORT=3001

# JWT Secret (fallback if Vault is disabled)
JWT_SECRET=8c653503e73f6cd2afc47a6c66ec768ecd56d59f792eea58cf22178dc35de431f49087f1d79fe13218ac9ed131925493944f38c5ab522400759ffdba0769cbee

# Admin User (fallback if Vault is disabled)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# HashiCorp Vault Configuration
VAULT_ENABLED=false
VAULT_ENDPOINT=http://localhost:8200
VAULT_TOKEN=personal-dev-root-token-123
VAULT_API_VERSION=v1

# Supabase Database credentials (fallback if Vault is disabled)
DB_HOST=db.[YOUR-PROJECT-REF].supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=[YOUR-SUPABASE-PASSWORD]
DATABASE_CONNECTION_STRING=postgresql://postgres:[YOUR-SUPABASE-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DB_SSL_MODE=require

# Supabase (required for API + Storage uploads)
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=[YOUR-SERVICE-ROLE-KEY]

# Supabase Storage (images for blog & projects; create bucket — see supabase-storage-setup.sql)
SUPABASE_STORAGE_BUCKET=portfolio-media
# Optional folder prefix inside the bucket (no leading/trailing slashes)
SUPABASE_STORAGE_PREFIX=site

# File upload size limit (bytes)
MAX_FILE_SIZE=5242880

# CORS
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3002
